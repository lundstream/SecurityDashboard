{
  "siteName": "Security dashboard",
  "logo": "",
  "server": {
    "port": 3000
  },
  "polling": {
    "cveIntervalMinutes": 10,
    "newsIntervalMinutes": 5,
    "uptimeIntervalMinutes": 60,
    "cveMaxAgeDays": 60,
    "newsMaxAgeDays": 60,
    "uptimeMaxAgeDays": 30,
    "uptimeDisplayHours": 24,
    "uptimePrefillDays": 30,
    "cveInitialFetchCount": 100
  },
  "services": {
    "microsoft": {
      "hosts": [
        "https://outlook.office365.com/",
        "https://advania-my.sharepoint.com/",
        "https://login.microsoftonline.com/",
        "https://portal.office.com/"
      ],
